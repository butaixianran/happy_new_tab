{
  "manifest_version": 3,
  "name": "Happy New Tab",
  "version": "1.0.1",
  "description": "A powerful tab management tool replacing new tab page.",
  "author": "butaixianran",

  "icons": {
    "128": "icon128.png"
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": { "128": "icon128.png" }
  },

  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },

  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },

  "background": {
    "service_worker": "background.js"
  },

  "permissions": [
    "storage",
    "unlimitedStorage",
    "tabs",
    "identity"
  ],

  "host_permissions": [
    "https://api.github.com/*",
    "https://content.dropboxapi.com/*",
    "https://api.dropboxapi.com/*",
    "https://www.dropbox.com/*",
    "https://dav.jianguoyun.com/*",
    "https://*.chromiumapp.org/*"
  ],

  "web_accessible_resources": [
    {
      "resources": ["icon128.png", "font/MaterialIcons-Regular.woff2"],
      "matches": ["<all_urls>"]
    }
  ]
}
